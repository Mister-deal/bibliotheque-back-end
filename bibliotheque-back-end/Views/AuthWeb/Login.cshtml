@model BibliothequeBackEnd.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Connexion";
    Layout = "_Layout";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
        <div>
            <div class="mx-auto h-16 w-16 bg-gradient-to-br from-amber-400 to-amber-600 rounded-xl flex items-center justify-center shadow-lg">
                <i class="fas fa-book-open text-white text-2xl"></i>
            </div>
            <h2 class="mt-6 text-center text-4xl font-extrabold text-gray-900">
                Connectez-vous à votre compte
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Ou <a asp-action="Register" class="font-medium text-amber-600 hover:text-amber-500 transition-colors duration-200">créez un nouveau compte</a>
            </p>
        </div>

        <!-- Message de succès (après inscription) -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
                <span class="block sm:inline">@TempData["SuccessMessage"]</span>
            </div>
        }

        <!-- Formulaire MVC -->
        <form class="mt-8 space-y-6" asp-controller="AuthWeb" asp-action="Login" method="POST">
            @Html.AntiForgeryToken()

            <!-- Messages d'erreur globaux -->
            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""].Errors.Count > 0)
            {
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
                    <strong class="font-bold">Erreur :</strong>
                    @foreach (var error in ViewData.ModelState[""].Errors)
                    {
                        <span class="block sm:inline">@error.ErrorMessage</span>
                    }
                </div>
            }

            <div class="rounded-md shadow-sm -space-y-px">
                <div>
                    <label asp-for="EmailOrUsername" class="sr-only">Adresse email ou Nom d'utilisateur</label>
                    <input asp-for="EmailOrUsername" type="text" required
                           class="appearance-none rounded-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-t-md focus:outline-none focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm transition-colors duration-200 @(Html.ViewData.ModelState["EmailOrUsername"]?.Errors.Count > 0 ? "border-red-500" : "")"
                           placeholder="Adresse email ou Nom d'utilisateur">
                    <span asp-validation-for="EmailOrUsername" class="text-red-500 text-sm mt-1 block"></span>
                </div>
                <div>
                    <label asp-for="Password" class="sr-only">Mot de passe</label>
                    <input asp-for="Password" type="password" required
                           class="appearance-none rounded-none relative block w-full px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-b-md focus:outline-none focus:ring-amber-500 focus:border-amber-500 focus:z-10 sm:text-sm transition-colors duration-200 @(Html.ViewData.ModelState["Password"]?.Errors.Count > 0 ? "border-red-500" : "")"
                           placeholder="Mot de passe">
                    <span asp-validation-for="Password" class="text-red-500 text-sm mt-1 block"></span>
                </div>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input asp-for="RememberMe" type="checkbox"
                           class="h-4 w-4 text-amber-600 focus:ring-amber-500 border-gray-300 rounded transition-colors duration-200">
                    <label asp-for="RememberMe" class="ml-2 block text-sm text-gray-900">
                        Se souvenir de moi
                    </label>
                </div>

                <div class="text-sm">
                    <a href="#" class="font-medium text-amber-600 hover:text-amber-500 transition-colors duration-200">
                        Mot de passe oublié?
                    </a>
                </div>
            </div>

            <div>
                <button type="submit"
                        class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-gradient-to-r from-amber-500 to-amber-600 hover:from-amber-600 hover:to-amber-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-amber-500 transform hover:scale-105 transition-all duration-200 shadow-lg hover:shadow-xl">
                    <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                        <i class="fas fa-lock text-amber-300 group-hover:text-amber-200"></i>
                    </span>
                    Se connecter
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Scripts de validation côté client (optionnel) -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
