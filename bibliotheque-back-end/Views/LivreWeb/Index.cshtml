@model IEnumerable<bibliotheque_back_end.Models.Livre>
@{
    ViewData["Title"] = "Gestion des Livres";
    Layout = "_AdminLTELayout"; // Assurez-vous que ce layout inclut le CDN Tailwind CSS
}

<!-- Assurez-vous que le CDN Tailwind CSS est inclus dans votre _AdminLTELayout.cshtml -->
<!-- Exemple: <script src="https://cdn.tailwindcss.com"></script> -->
<!-- Et la police Inter si vous l'utilisez: <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"> -->
<!-- Font Awesome CDN pour les icônes (si non déjà inclus dans _AdminLTELayout) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">


<div class="container mx-auto px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header avec titre et boutons -->
    <div class="flex flex-col sm:flex-row justify-between items-center mb-8">
        <h1 class="text-4xl font-extrabold text-gray-900 leading-tight mb-4 sm:mb-0">Gestion des Livres</h1>
        <a asp-action="Create" class="bg-green-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg hover:bg-green-700 transition-colors duration-200 text-lg flex items-center gap-2">
            <i class="fas fa-plus-circle"></i> Ajouter un livre
        </a>
    </div>

    <!-- Barre de recherche -->
    <div class="mb-8">
        <form method="get" asp-action="Index" class="relative max-w-xl mx-auto">
            <div class="flex shadow-md rounded-lg overflow-hidden">
                <input type="text"
                       name="searchTerm"
                       class="flex-1 px-4 py-3 border border-gray-300 rounded-l-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-lg"
                       placeholder="Rechercher un livre par titre ou auteur..."
                       value="@ViewData["CurrentFilter"]">
                <button class="bg-blue-600 text-white font-semibold px-6 py-3 rounded-r-lg hover:bg-blue-700 transition-colors duration-200 flex items-center justify-center" type="submit">
                    <i class="fas fa-search"></i> <span class="ml-2 hidden sm:inline">Rechercher</span>
                </button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="bg-gray-300 text-gray-800 font-semibold px-4 py-3 rounded-r-lg ml-1 hover:bg-gray-400 transition-colors duration-200 flex items-center justify-center">
                        <i class="fas fa-times"></i> <span class="ml-2 hidden sm:inline">Effacer</span>
                    </a>
                }
            </div>
        </form>
    </div>

    <!-- Messages d'erreur ou de succès -->
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative mb-6" role="alert">
            <strong class="font-bold">Erreur :</strong> @ViewBag.ErrorMessage
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded-lg relative mb-6" role="alert">
            <strong class="font-bold">Succès :</strong> @TempData["SuccessMessage"]
        </div>
    }

    <!-- Liste des livres -->
    @if (Model.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var livre in Model)
            {
                <div class="bg-white rounded-xl shadow-lg overflow-hidden flex flex-col transition-transform duration-300 ease-in-out hover:scale-[1.01] hover:shadow-xl">
                    <div class="p-6 flex flex-col flex-grow">
                        <h5 class="text-2xl font-bold text-blue-700 mb-2 leading-tight">@livre.Titre</h5>
                        <h6 class="text-lg text-gray-600 mb-4 font-medium">👤 @livre.Auteur</h6>
                        @if (!string.IsNullOrEmpty(livre.Description))
                        {
                            <p class="text-gray-700 text-base mb-4 flex-grow">
                                @(livre.Description.Length > 120 ? livre.Description.Substring(0, 120) + "..." : livre.Description)
                            </p>
                        }
                        else
                        {
                            <p class="text-gray-500 text-base mb-4 flex-grow italic">Pas de description disponible.</p>
                        }

                        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4 text-gray-600 text-sm">
                            <span>📅 @livre.AnneePublication</span>
                            @if (!string.IsNullOrEmpty(livre.Editeur))
                            {
                                <span>• 🏢 @livre.Editeur</span>
                            }
                        </div>
                        <div class="flex flex-wrap gap-2 mb-4">
                            <span class="inline-block px-4 py-1.5 rounded-full bg-gray-200 text-gray-800 text-sm font-semibold">
                                📚 @livre.Categorie
                            </span>
                            <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold
                                @(livre.Etat == bibliotheque_back_end.Models.EtatLivre.Disponible ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                                📊 @livre.Etat
                            </span>
                        </div>
                    </div>
                    <div class="p-4 bg-gray-50 border-t border-gray-200">
                        <div class="flex flex-col sm:flex-row gap-2 justify-center">
                            <a asp-action="Details" asp-route-id="@livre.Id" class="flex-1 text-center bg-blue-500 text-white font-semibold py-2 px-4 rounded-lg hover:bg-blue-600 transition-colors duration-200 text-sm">
                                <i class="fas fa-eye"></i> Voir
                            </a>
                            <a asp-action="Edit" asp-route-id="@livre.Id" class="flex-1 text-center bg-yellow-500 text-white font-semibold py-2 px-4 rounded-lg hover:bg-yellow-600 transition-colors duration-200 text-sm">
                                <i class="fas fa-edit"></i> Modifier
                            </a>
                            <a asp-action="Delete" asp-route-id="@livre.Id" class="flex-1 text-center bg-red-600 text-white font-semibold py-2 px-4 rounded-lg hover:bg-red-700 transition-colors duration-200 text-sm">
                                <i class="fas fa-trash-alt"></i> Supprimer
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <!-- Message si aucun livre -->
        <div class="text-center py-16 bg-white rounded-xl shadow-lg mt-8">
            <div class="mb-6">
                <i class="fas fa-frown-open text-gray-400 text-6xl mb-4"></i>
                <h3 class="text-gray-700 text-3xl font-bold mb-3">Aucun livre trouvé</h3>
                <p class="text-gray-500 text-lg">Commencez par ajouter votre premier livre à la bibliothèque.</p>
            </div>
            <a asp-action="Create" class="bg-blue-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg hover:bg-blue-700 transition-colors duration-200 text-lg flex items-center justify-center mx-auto w-fit">
                <i class="fas fa-plus-circle"></i> Ajouter un livre
            </a>
        </div>
    }
</div>