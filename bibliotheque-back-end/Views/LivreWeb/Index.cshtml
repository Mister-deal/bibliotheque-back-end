@model IEnumerable<bibliotheque_back_end.Models.Livre>
@{
    ViewData["Title"] = "Liste des Livres";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📚 Gestion des Livres</h1>
        <a asp-action="Create" class="btn btn-success">➕ Ajouter un livre</a>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger">@ViewBag.ErrorMessage</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="row">
        @foreach (var livre in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary">@livre.Titre</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@livre.Auteur</h6>

                        @if (!string.IsNullOrEmpty(livre.Description))
                        {
                            <p class="card-text text-muted small">
                                @(livre.Description.Length > 100 ? livre.Description.Substring(0, 100) + "..." : livre.Description)
                            </p>
                        }

                        <div class="card-text mb-3">
                            <small class="text-muted">
                                📅 @livre.AnneePublication
                                @if (!string.IsNullOrEmpty(livre.Editeur))
                                {
                                    <span>• 🏢 @livre.Editeur</span>
                                }
                                <br>
                                📚 <span class="badge bg-secondary">@livre.Categorie</span>
                                📊 <span class="badge @(livre.Etat == bibliotheque_back_end.Models.EtatLivre.Disponible ? "bg-success" : "bg-danger")">
                                    @livre.Etat
                                </span>
                            </small>
                        </div>

                        <div class="mt-auto">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Details" asp-route-id="@livre.Id" class="btn btn-outline-info btn-sm">👁️</a>
                                <a asp-action="Edit" asp-route-id="@livre.Id" class="btn btn-outline-warning btn-sm">✏️</a>
                                <a asp-action="Delete" asp-route-id="@livre.Id" class="btn btn-outline-danger btn-sm">🗑️</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h3 class="text-muted">📚 Aucun livre trouvé</h3>
            <p>Commencez par ajouter votre premier livre !</p>
            <a asp-action="Create" class="btn btn-primary btn-lg">➕ Ajouter un livre</a>
        </div>
    }
</div>
