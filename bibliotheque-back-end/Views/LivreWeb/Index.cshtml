@model IEnumerable<bibliotheque_back_end.Models.Livre>
@{
    Layout = "_AdminLTELayout";
}

<div class="container-fluid">
    <!-- Header avec titre et boutons -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0 fs-2">Gestion des Livres</h1>
        <a asp-action="Create" class="btn btn-success btn-lg">Ajouter un livre</a>
    </div>

    <!-- Barre deecherche -->
    <div class="mb-4">
        <form method="get" asp-action="Index" class="position-relative">
            <div class="input-group shadow-sm" style="max-width: 500px; margin: 0 auto;">
                <input type="text"
                       name="searchTerm"
                       class="form-control"
                       placeholder=" Rechercher..."
                       value="@ViewData["CurrentFilter"]">
                <button class="btn btn-outline-primary" type="submit">Go</button>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">✕</a>
                }
            </div>
        </form>
    </div>

    <!-- Messages d'erreur ou de succès -->
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger fs-6">@ViewBag.ErrorMessage</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success fs-6">@TempData["SuccessMessage"]</div>
    }

    <!-- Liste des livres -->
    <div class="row g-3">
        @foreach (var livre in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-primary mb-2 fw-bold fs-4">@livre.Titre</h5>
                        <h6 class="card-subtitle mb-3 text-secondary fs-5">@livre.Auteur</h6>
                        @if (!string.IsNullOrEmpty(livre.Description))
                        {
                            <p class="card-text text-muted mb-3 fs-6">
                                @(livre.Description.Length > 100 ? livre.Description.Substring(0, 100) + "..." : livre.Description)
                            </p>
                        }
                        <div class="card-text mb-4">
                            <div class="d-flex flex-wrap gap-2 mb-2">
                                <span class="text-muted fs-6">@livre.AnneePublication</span>
                                @if (!string.IsNullOrEmpty(livre.Editeur))
                                {
                                    <span class="text-muted fs-6">• @livre.Editeur</span>
                                }
                            </div>
                            <div class="d-flex gap-2">
                                <span class="badge bg-secondary fs-6 py-2 px-3">@livre.Categorie</span>
                                <span class="badge @(livre.Etat == bibliotheque_back_end.Models.EtatLivre.Disponible ? "bg-success" : "bg-danger") fs-6 py-2 px-3">
                                    @livre.Etat
                                </span>
                            </div>
                        </div>
                        <div class="mt-auto">
                            <div class="btn-group w-100" role="group">
                                <a asp-action="Details" asp-route-id="@livre.Id" class="btn btn-outline-info btn-sm fs-6">Voir</a>
                                <a asp-action="Edit" asp-route-id="@livre.Id" class="btn btn-outline-warning btn-sm fs-6">Modifier</a>
                                <a asp-action="Delete" asp-route-id="@livre.Id" class="btn btn-outline-danger btn-sm fs-6">Supprimer</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Message si aucun livre -->
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <h3 class="text-muted mb-3 fs-3">Aucun livre trouvé</h3>
                <p class="text-muted fs-5">Commencez par ajouter votre premier livre</p>
            </div>
            <a asp-action="Create" class="btn btn-primary btn-lg fs-5">Ajouter un livre</a>
        </div>
    }
</div>