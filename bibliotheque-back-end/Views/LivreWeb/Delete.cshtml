@model bibliotheque_back_end.Models.Livre
@{
    ViewData["Title"] = "Supprimer - " + Model.Titre;
    Layout = "_AdminLTELayout";
}

<div class="container">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">🗑️ Supprimer le Livre</h3>
                </div>

                <div class="card-body">
                    <div class="alert alert-warning">
                        <h5 class="alert-heading">⚠️ Attention !</h5>
                        <p class="mb-0">Vous êtes sur le point de supprimer définitivement ce livre. Cette action est <strong>irréversible</strong>.</p>
                    </div>

                    @if (Model.Etat != bibliotheque_back_end.Models.EtatLivre.Disponible)
                    {
                        <div class="alert alert-danger">
                            <h6 class="alert-heading">❌ Livre non disponible</h6>
                            <p class="mb-0">Ce livre n'est pas disponible (état: @Model.Etat). Vérifiez son statut avant de le supprimer.</p>
                        </div>
                    }

                    <div class="row">
                        <div class="col-12">
                            <h4 class="text-primary mb-3">@Model.Titre</h4>
                            <h6 class="text-muted mb-4">👤 @Model.Auteur</h6>

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <div class="mb-3">
                                    <strong>📝 Description :</strong>
                                    <p class="text-muted">@Model.Description</p>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-5">📅 Année :</dt>
                                <dd class="col-7">@Model.AnneePublication</dd>

                                @if (!string.IsNullOrEmpty(Model.Editeur))
                                {
                                    <dt class="col-5">🏢 Éditeur :</dt>
                                    <dd class="col-7">@Model.Editeur</dd>
                                }

                                <dt class="col-5">📚 Catégorie :</dt>
                                <dd class="col-7">
                                    <span class="badge bg-secondary">@Model.Categorie</span>
                                </dd>
                            </dl>
                        </div>

                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-5">🆔 ID :</dt>
                                <dd class="col-7"><code>#@Model.Id</code></dd>

                                <dt class="col-5">📊 État :</dt>
                                <dd class="col-7">
                                    <span class="badge @(Model.Etat == bibliotheque_back_end.Models.EtatLivre.Disponible ? "bg-success" : "bg-danger")">
                                        @Model.Etat
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-light">
                    <form asp-action="Delete" method="post" class="d-inline">
                        <input asp-for="Id" type="hidden" />
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="submit" class="btn btn-danger btn-lg"
                                    onclick="return confirm('Êtes-vous vraiment sûr de vouloir supprimer ce livre ?')">
                                🗑️ Oui, supprimer définitivement
                            </button>
                            <a asp-action="Index" class="btn btn-secondary btn-lg">
                                ❌ Non, annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
