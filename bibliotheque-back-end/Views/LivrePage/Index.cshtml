@{
}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>

@await Html.PartialAsync("_Header")

<body>
    <main class="pt-5">
@await Html.PartialAsync("_BarreRecherche")

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        @foreach (var livre in Model)
        {
            <div class="bg-white rounded-xl shadow-lg overflow-hidden flex flex-col transition-transform duration-300 ease-in-out hover:scale-[1.01] hover:shadow-xl">
                <div class="p-6 flex flex-col flex-grow">
                    <h5 class="text-2xl font-bold text-blue-700 mb-2 leading-tight">@livre.Titre</h5>
                    <h6 class="text-lg text-gray-600 mb-4 font-medium">👤 @livre.Auteur</h6>
                    @if (!string.IsNullOrEmpty(livre.Description))
                    {
                        <p class="text-gray-700 text-base mb-4 flex-grow">
                            @(livre.Description.Length > 120 ? livre.Description.Substring(0, 120) + "..." : livre.Description)
                        </p>
                    }
                    else
                    {
                        <p class="text-gray-500 text-base mb-4 flex-grow italic">Pas de description disponible.</p>
                    }

                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-4 text-gray-600 text-sm">
                        <span> @livre.AnneePublication</span>
                        @if (!string.IsNullOrEmpty(livre.Editeur))
                        {
                            <span>•  @livre.Editeur</span>
                        }
                    </div>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="inline-block px-4 py-1.5 rounded-full bg-gray-200 text-gray-800 text-sm font-semibold">
                             @livre.Categorie
                        </span>
                        <span class="inline-block px-4 py-1.5 rounded-full text-sm font-semibold
                                    @(livre.Etat == bibliotheque_back_end.Models.EtatLivre.Disponible ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                             @livre.Etat
                        </span>
                    </div>
                </div>
                <div class="p-4 bg-gray-50 border-t border-gray-200">
                    <div class="flex flex-col sm:flex-row gap-2 justify-center">
                        <a asp-action="Details" 
                        asp-route-id="@livre.Id" 
                        class="flex-1 text-center bg-blue-500 text-white font-semibold py-2 px-4 rounded-lg hover:bg-blue-600 transition-colors duration-200 text-sm">
                            <i class="fas fa-eye"></i> Voir
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    </main>
</body>

@await Html.PartialAsync("_Footer")
