@{
}
<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] -Simplon Bibliothèque: Admin Space</title>

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="~/lib/admin-lte/css/adminlte.min.css">
    <!-- Placez cette ligne dans la section <head> de votre fichier _Layout.cshtml ou équivalent -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS CDN - Placez-le avant votre propre CSS si vous avez des overrides -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="hold-transition sidebar-mini">
    <div class="wrapper">

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Retour à la page d'accueil</a>
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav ml-auto">
                <li class="nav-item">
                    <a class="nav-link" href="#">
                        <i class="fas fa-user"></i> Admin
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Sidebar -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a href="#" class="brand-link">
                <i class="fas fa-book brand-image"></i>
                <span class="brand-text font-weight-light">Bibliothèque</span>
            </a>

            <div class="sidebar">
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" role="menu">
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Dashboard")" class="nav-link">
                                <i class="nav-icon fas fa-tachometer-alt"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "LivreWeb")" class="nav-link">
                                <i class="nav-icon fas fa-book"></i>
                                <p>Livres</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "WIP")" class="nav-link">
                                <i class="nav-icon fas fa-user-edit"></i>
                                <p>Emprunts en cours</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "WIP")" class="nav-link">
                                <i class="nav-icon fas fa-user-edit"></i>
                                <p>Membres</p>
                            </a>
                        </li>
                        @* Ici, pour rajouter les chemins futur ! *@
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Contenu principal -->
        <div class="content-wrapper">
            <div class="content-header">
                <div class="container-fluid">
                    <h1>@ViewData["Title"]</h1>
                </div>
            </div>

            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/admin-lte/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
