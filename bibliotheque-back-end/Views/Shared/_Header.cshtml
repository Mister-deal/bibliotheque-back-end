@{
}
<header class="bg-[#b4936c] py-6 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between gap-8 sm:px-4">
        <div class="flex items-center gap-3">
            <img src="~/images/logo.jpeg" alt="Logo Bibliothèque Simplon" class="w-14 h-14 object-cover rounded-full shadow-md" />
            <div class="text-white text-2xl font-bold tracking-wide">BIBLIOTHÈQUE Simplon</div>
        </div>
        <div class="flex-1 max-w-xl mx-4">
            <input type="text" placeholder="Recherche..." class="w-full py-2.5 px-4 rounded-lg text-base text-gray-800 focus:outline-none focus:ring-2 focus:ring-white focus:border-transparent transition-all duration-200" />
        </div>
        <a asp-area="" asp-controller="AuthWeb" asp-action="Login" class="min-w-[120px] text-center py-3 px-4 bg-gray-200 rounded-lg text-gray-800 text-lg font-semibold shadow-md cursor-pointer hover:bg-gray-300 transition-colors duration-200">UTILISATEUR</a>
        <a class="text-white hover:text-gray-200 transition-colors duration-200 text-lg font-medium whitespace-nowrap" asp-area="" asp-controller="Dashboard" asp-action="Index">Accès Dashboard</a>
    </div>
</header>