@{
}
<header class="bg-[#9C7853] py-6 shadow-lg">
    <div class="max-w-7xl mx-auto px-6 sm:px-4"/>
    <div class="flex items-center justify-between gap-8">

        <!-- Logo et titre -->
        <a asp-controller="Home" asp-action="Index"
           class="flex items-center gap-3 text-decoration-none hover:opacity-80 transition-opacity duration-200">
            <img src="~/images/logo.jpeg"
                 alt="Logo Bibliothèque Simplon"
                 class="w-14 h-14 object-cover rounded-full shadow-md border-2 border-[#F5F1E8]"/>
            <div class="text-[#F5F1E8] text-2xl font-bold tracking-wide">
                BIBLIOTHÈQUE Simplon
            </div>
        </a>

        <!-- Navigation simple -->
        <nav class="flex gap-6">
            <a asp-controller="LivrePage"
               asp-action="Index"
               class="text-[#F5F1E8] text-lg font-medium hover:text-white transition-colors duration-200 text-decoration-none">
                Livres
            </a>
            <a asp-controller=""
               asp-action=""
               class="text-[#F5F1E8] text-lg font-medium hover:text-white transition-colors duration-200 text-decoration-none">
                CGU
            </a>
        </nav>

        <!-- Section utilisateur dynamique -->
        <div class="flex items-center gap-4">
            @if (User.Identity.IsAuthenticated)
            {
                <!-- Utilisateur connecté -->
                <div class="flex items-center gap-3">
                    <!-- Nom de l'utilisateur -->
                    <div class="text-[#F5F1E8]">
                        <i class="fas fa-user mr-2"></i>
                        <span class="font-medium">
                            Bonjour, @(
                                     User.FindFirst("given_name")?.Value ??
                                     User.FindFirst("firstname")?.Value ??
                                     User.FindFirst("prenom")?.Value ??
                                     User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value ??
                                     User.FindFirst("name")?.Value ??
                                     User.Identity.Name ??
                                     "Utilisateur"
                                     )
                        </span>
                    </div>

                    <!-- Bouton Dashboard -->
                    <a class="text-[#F5F1E8] hover:text-[#D4B896] transition-colors duration-200 text-sm font-medium whitespace-nowrap flex items-center gap-1"
                       asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-tachometer-alt"></i>
                        Dashboard
                    </a>

                    <!-- Bouton Déconnexion -->
                    <form asp-controller="AuthWeb" asp-action="Logout" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit"
                                class="min-w-[120px] text-center py-2 px-4 bg-[#8B4513] hover:bg-[#A0522D] rounded-lg text-[#F5F1E8] text-sm font-semibold shadow-md transition-colors duration-200 flex items-center justify-center gap-2"
                                onclick="return confirm('Êtes-vous sûr de vouloir vous déconnecter ?')">
                            <i class="fas fa-sign-out-alt"></i>
                            Déconnexion
                        </button>
                    </form>
                </div>
            }
            else
            {
                <!-- Utilisateur non connecté -->
                <div class="flex items-center gap-3">
                    <!-- Bouton Connexion -->
                    <a asp-controller="AuthWeb" asp-action="Login"
                       class="min-w-[100px] text-center py-2 px-4 bg-[#724232] hover:bg-[#8D6E63] rounded-lg text-[#F5F1E8] text-sm font-semibold shadow-md transition-colors duration-200 flex items-center justify-center gap-2">
                        <i class="fas fa-sign-in-alt"></i>
                        Connexion
                    </a>

                    <!-- Bouton Inscription -->
                    <a asp-controller="AuthWeb" asp-action="Register"
                       class="min-w-[100px] text-center py-2 px-4 bg-[#724232] hover:bg-[#8D6E63] rounded-lg text-[#F5F1E8] text-sm font-semibold shadow-md transition-colors duration-200 flex items-center justify-center gap-2">
                        <i class="fas fa-user-plus"></i>
                        Inscription
                    </a>
                </div>


            }
        </div>
    </div>
</header>
