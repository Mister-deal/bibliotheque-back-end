@{
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Work In Progress - Bibliothèque Simplon</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-gradient-to-br from-orange-100 to-yellow-50 min-h-screen">

    <!-- Header -->
    <header class="bg-[#9C7853] py-4 shadow-lg">
        <div class="max-w-7xl mx-auto px-6">
            <a asp-controller="Home" asp-action="Index"
               class="flex items-center gap-3 text-decoration-none hover:opacity-80 transition-opacity duration-200">
                <img src="~/images/logo.jpeg"
                     alt="Logo Bibliothèque Simplon"
                     class="w-12 h-12 object-cover rounded-full shadow-md border-2 border-[#F5F1E8]" />
                <div class="text-[#F5F1E8] text-xl font-bold tracking-wide">
                    BIBLIOTHÈQUE Simplon
                </div>
            </a>
        </div>
    </header>

    <!-- Main Content -->
    <div class="flex items-center justify-center min-h-screen py-12 px-4">
        <div class="max-w-4xl mx-auto text-center">

            <!-- Construction Image -->
            <div class="mb-8">
                <img src="https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                     alt="Travailleur sur un chantier"
                     class="w-64 h-64 mx-auto object-cover rounded-full shadow-2xl border-8 border-white" />
            </div>

            <!-- Construction Icons -->
            <div class="flex justify-center space-x-6 mb-8 text-orange-500 text-4xl">
                <i class="fas fa-hard-hat animate-bounce"></i>
                <i class="fas fa-hammer animate-pulse"></i>
                <i class="fas fa-wrench animate-bounce" style="animation-delay: 0.2s;"></i>
                <i class="fas fa-screwdriver animate-pulse" style="animation-delay: 0.4s;"></i>
            </div>

            <!-- Main Title -->
            <h1 class="text-6xl font-bold text-[#9C7853] mb-4">
                🚧 WORK IN PROGRESS 🚧
            </h1>

            <!-- Subtitle -->
            <h2 class="text-2xl font-semibold text-gray-700 mb-6">
                Cette page est en cours de construction !
            </h2>

            <!-- Description -->
            <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto leading-relaxed">
                Nos développeurs travaillent dur pour vous apporter cette fonctionnalité.
                Revenez bientôt pour découvrir les nouveautés !
            </p>

            <!-- Progress Bar -->
            <div class="mb-8">
                <div class="bg-gray-200 rounded-full h-4 max-w-md mx-auto">
                    <div class="bg-gradient-to-r from-orange-400 to-yellow-500 h-4 rounded-full animate-pulse"
                         style="width: 65%"></div>
                </div>
                <p class="text-sm text-gray-500 mt-2">65% terminé</p>
            </div>

            <!-- Back Button -->
            <div class="space-y-4">
                <a asp-controller="Home" asp-action="Index"
                   class="inline-flex items-center bg-[#9C7853] text-white px-8 py-3 rounded-lg font-semibold hover:bg-[#8a6b47] transition-colors duration-300 text-decoration-none shadow-lg">
                    <i class="fas fa-arrow-left mr-2"></i>
                    Retour à l'accueil
                </a>

                <div class="text-sm text-gray-500">
                    <i class="fas fa-clock mr-1"></i>
                    Dernière mise à jour : @DateTime.Now.ToString("dd/MM/yyyy")
                </div>
            </div>

        </div>
    </div>

    <!-- Footer Fun -->
    <footer class="text-center py-8 text-gray-500">
        <div class="flex justify-center items-center space-x-2 text-sm">
            <i class="fas fa-coffee text-brown-500"></i>
            <span>Alimenté par du café et de la détermination</span>
            <i class="fas fa-heart text-red-500"></i>
        </div>
    </footer>

</body>
</html>
