@{
    Layout = "_AdminLTELayout"; // Assurez-vous que ce layout inclut le CDN Tailwind CSS
}
@model BibliothequeBackEnd.Models.ViewModels.DashboardViewModel

<!-- Assurez-vous que le CDN Tailwind CSS est inclus dans votre _AdminLTELayout.cshtml -->
<!-- Exemple: <script src="https://cdn.tailwindcss.com"></script> -->
<!-- Et la police Inter si vous l'utilisez: <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"> -->
<!-- Font Awesome CDN pour les icônes (si non déjà inclus dans _AdminLTELayout) -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">


<div class="px-4 py-6 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
        <div class="flex flex-col sm:flex-row items-center justify-between mb-8">
            <h1 class="text-4xl font-extrabold text-gray-900 leading-tight mb-4 sm:mb-0">Tableau de bord</h1>
        </div>
    </div>
</div>

<section class="pb-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        <!-- Statistiques -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-10">
            <!-- Livre disponibles -->
            <div class="bg-white rounded-xl shadow-lg p-6 flex items-center justify-between transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-xl border border-gray-200">
                <div>
                    <h3 class="text-4xl font-bold text-gray-900 mb-1">@Model.TotalBooks</h3>
                    <p class="text-gray-600 text-lg">Livres disponibles</p>
                </div>
                <div class="text-blue-600 text-5xl">
                    <i class="fas fa-book"></i>
                </div>
            </div>

            <!-- Utilisateurs actifs -->
            <div class="bg-white rounded-xl shadow-lg p-6 flex items-center justify-between transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-xl border border-gray-200">
                <div>
                    <h3 class="text-4xl font-bold text-gray-900 mb-1">@Model.TotalUsers</h3>
                    <p class="text-gray-600 text-lg">Utilisateurs actifs</p>
                </div>
                <div class="text-gray-700 text-5xl">
                    <i class="fas fa-users"></i>
                </div>
            </div>

            <!-- Emprunts aujourd'hui -->
            <div class="bg-white rounded-xl shadow-lg p-6 flex items-center justify-between transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-xl border border-gray-200">
                <div>
                    <h3 class="text-4xl font-bold text-gray-900 mb-1">@Model.TodayLoans</h3>
                    <p class="text-gray-600 text-lg">Emprunts aujourd'hui</p>
                </div>
                <div class="text-purple-600 text-5xl">
                    <i class="fas fa-handshake"></i>
                </div>
            </div>

            <!-- Retours en retard -->
            <div class="bg-white rounded-xl shadow-lg p-6 flex items-center justify-between transition-transform duration-300 ease-in-out hover:scale-105 hover:shadow-xl border border-gray-200">
                <div>
                    <h3 class="text-4xl font-bold text-gray-900 mb-1">@Model.PendingReturns</h3>
                    <p class="text-red-500 text-lg font-semibold">Retours en retard</p>
                </div>
                <div class="text-red-500 text-5xl">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
            </div>
        </div>

        <!-- Activités récentes -->
        <div class="bg-white rounded-xl shadow-lg overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-200 flex items-center">
                <h3 class="text-2xl font-semibold text-gray-900 flex items-center">
                    <i class="fas fa-history mr-3 text-gray-600"></i>
                    Activités récentes
                </h3>
            </div>
            <div class="p-6">
                @foreach (var activity in Model.RecentActivities)
                {
                    <div class="flex items-start justify-between py-4 border-b border-gray-200 last:border-b-0">
                        <div class="flex-grow">
                            <h6 class="text-lg font-medium text-gray-900 mb-1 flex items-center">
                                <i class="fas fa-@activity.Icon mr-3 text-gray-600"></i>
                                @activity.Title
                            </h6>
                            <p class="text-gray-600 text-base">@activity.Description</p>
                        </div>
                        <small class="text-gray-500 text-sm whitespace-nowrap ml-4">@activity.Time.ToString("dd/MM HH:mm")</small>
                    </div>
                }
            </div>
        </div>

    </div>
</section>
