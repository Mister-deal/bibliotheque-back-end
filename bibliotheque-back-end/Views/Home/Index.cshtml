@{
    ViewData["Title"] = "Home Page";
}

@await Html.PartialAsync("_Header")

<main>
    <!-- Grosse image centrale -->
    <div class="main-image">
        <img src="images/img1.jpg" />
    </div>
    <!-- Actualités -->
    <div class="actualites">
        <div class="actualite-img"><img src="images/img1.jpg"/></div>
        <div class="actualite-img"><img src="images/img2.jpg" /></div>
        <div class="actualite-img"><img src="images/img3.jpg" /></div>
    </div>
    <div class="actions-center">
        <button class="btn-light">Voir tous les livres</button>
    </div>
</main>

<!-- Agenda -->
<section class="agenda-section">
    <div class="agenda-content bg-white">
        <div class="agenda-title">AGENDA</div>
        <div class="actualites">
            <div class="actualite-img"><img src="images/img1.jpg" /></div>
            <div class="actualite-img"><img src="images/img2.jpg" /></div>
            <div class="actualite-img"><img src="images/img3.jpg" /></div>
        </div>
        <div class="actions-center">
            <button class="btn-light">Voir tous les événements</button>
        </div>
    </div>
</section>

@await Html.PartialAsync("_Footer")

<!-- Style CSS -->
<style>
    :root {
        --marron: #b4936c;
        --noir: #232323;
        --blanc: #fff;
        --gris-img: #d8d8d8;
        --gris-bg: #f8f8f8;
        --gris-btn: #e3e3e3;
    }

    body {
        margin: 0;
        background: var(--gris-bg);
        font-family: 'Segoe UI', Arial, sans-serif;
        color: var(--noir);
    }

    /* MAIN */
    main {
        max-width: 1180px;
        margin: 0 auto;
        padding: 24px 2rem 0 2rem;
    }

    .main-image {
        background: var(--gris-img);
        max-width: 900px;
        min-height: 360px;
        border-radius: 16px;
        margin: 2rem auto 2.5rem auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .main-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 16px;
            display: block;
        }

    .actualites {
        display: flex;
        gap: 2rem;
        justify-content: center;
        margin-bottom: 24px;
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .actualite-img {
        flex: 1 1 0%;
        max-width: 260px;
        aspect-ratio: 1 / 1;
        background: var(--gris-img);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .actualite-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.25s;
        }

    .actions-center {
        text-align: center;
        margin-bottom: 1.8rem;
    }

    .btn-light {
        background: var(--gris-btn);
        color: var(--noir);
        border: none;
        border-radius: 3px;
        padding: 5px 14px;
        font-size: 1rem;
        cursor: pointer;
        margin-top: 2px;
        transition: background 0.2s;
    }

        .btn-light:hover {
            background: #e0e0e0;
        }

    /* AGENDA */
    .agenda-section {
        background: var(--marron);
        color: var(--noir);
        margin: 36px 0 0 0;
        padding: 34px 0 26px 0;
    }

    .agenda-content {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 2rem;
    }

    .agenda-title {
        font-weight: 600;
        font-size: 1.2rem;
        margin-bottom: 16px;
        letter-spacing: 0.7px;
    }

</style>