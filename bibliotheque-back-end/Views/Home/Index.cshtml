@{
    ViewData["Title"] = "Home Page";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdn.tailwindcss.com"></script>

@await Html.PartialAsync("_Header")

<main class="max-w-7xl mx-auto px-6 py-12 sm:px-8 lg:px-10">
    <!-- Grosse image centrale - Image d'une bibliothèque moderne et accueillante -->
    <div class="relative bg-gray-100 max-w-6xl mx-auto min-h-[450px] rounded-3xl shadow-2xl overflow-hidden mb-16 flex items-center justify-center md:min-h-[350px] sm:min-h-[250px]">
        <img src="https://www.villedegarges.fr/sites/default/files/styles/header_inner_pages/public/mediatheque1.jpg.webp?itok=l09cKR_k" alt="Image d'une bibliothèque moderne et accueillante" class="w-full h-full object-cover rounded-3xl block transition-transform duration-500 ease-in-out hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent rounded-3xl flex items-end p-8">
            <h1 class="text-white text-4xl md:text-5xl font-extrabold leading-tight drop-shadow-lg">
                Votre bibliothèque en ligne
            </h1>
        </div>
    </div>

    <!-- Section Actualités -->
    <section class="text-center mb-20">
        <h2 class="text-4xl font-bold text-gray-900 mb-12 tracking-tight">Nos Actualités</h2>
        <div class="flex flex-wrap justify-center gap-8 max-w-6xl mx-auto">
            <!-- Actualité 1 -->
            <div class="flex-1 min-w-[300px] max-w-[380px] bg-white rounded-3xl shadow-xl overflow-hidden transition-all duration-300 ease-in-out hover:translate-y-[-8px] hover:shadow-2xl flex flex-col">
                <div class="w-full aspect-video bg-gray-200 overflow-hidden">
                    <img src="https://www.hachette.fr/sites/default/files/styles/manual_crop_831x554/public/content_types/article/field_image_principal/mes-petites-routines-compressor.jpg?itok=dZkgpgty" alt="Image d'une nouvelle collection de livres" class="w-full h-full object-cover transition-transform duration-300 ease-in-out hover:scale-105" />
                </div>
                <div class="p-7 flex-grow">
                    <h3 class="text-2xl font-semibold mb-3 text-gray-900 leading-snug">Nouvelle collection de printemps</h3>
                    <p class="text-gray-700 text-lg">Découvrez nos dernières acquisitions et les coups de cœur de nos bibliothécaires. Des romans aux essais, il y en a pour tous les goûts !</p>
                </div>
                <div class="p-7 pt-0">
                    <button class="w-full bg-[#b4936c] text-white py-3 px-6 rounded-xl text-base font-medium cursor-pointer transition-all duration-300 ease-in-out shadow-md hover:bg-[#a3825c] hover:translate-y-[-2px] hover:shadow-lg">En savoir plus</button>
                </div>
            </div>
            <!-- Actualité 2 -->
            <div class="flex-1 min-w-[300px] max-w-[380px] bg-white rounded-3xl shadow-xl overflow-hidden transition-all duration-300 ease-in-out hover:translate-y-[-8px] hover:shadow-2xl flex flex-col">
                <div class="w-full aspect-video bg-gray-200 overflow-hidden">
                    <img src="https://www.capcadeau.com/media/cache/product_offer_picture_gallery_lightbox/place/3878/8763-ecriture-de-nouvelles-1122.jpg" alt="Image d'un atelier d'écriture créative" class="w-full h-full object-cover transition-transform duration-300 ease-in-out hover:scale-105" />
                </div>
                <div class="p-7 flex-grow">
                    <h3 class="text-2xl font-semibold mb-3 text-gray-900 leading-snug">Atelier d'écriture créative</h3>
                    <p class="text-gray-700 text-lg">Rejoignez notre atelier mensuel pour libérer votre imagination et partager vos récits avec d'autres passionnés.</p>
                </div>
                <div class="p-7 pt-0">
                    <button class="w-full bg-[#b4936c] text-white py-3 px-6 rounded-xl text-base font-medium cursor-pointer transition-all duration-300 ease-in-out shadow-md hover:bg-[#a3825c] hover:translate-y-[-2px] hover:shadow-lg">S'inscrire</button>
                </div>
            </div>
            <!-- Actualité 3 -->
            <div class="flex-1 min-w-[300px] max-w-[380px] bg-white rounded-3xl shadow-xl overflow-hidden transition-all duration-300 ease-in-out hover:translate-y-[-8px] hover:shadow-2xl flex flex-col">
                <div class="w-full aspect-video bg-gray-200 overflow-hidden">
                    <img src="https://actualitte.com/media/cache/width_944_webp/uploads/images/contes-d-hier-et-d-aujourd-hui-une-litterature-aux-multiples-imaginaires-629493a6583c8615732941.jpg" alt="Image d'une heure du conte pour enfants" class="w-full h-full object-cover transition-transform duration-300 ease-in-out hover:scale-105" />
                </div>
                <div class="p-7 flex-grow">
                    <h3 class="text-2xl font-semibold mb-3 text-gray-900 leading-snug">Heure du conte pour les petits</h3>
                    <p class="text-gray-700 text-lg">Chaque mercredi, des histoires magiques et des aventures captivantes attendent les jeunes lecteurs dans notre espace jeunesse.</p>
                </div>
                <div class="p-7 pt-0">
                    <button class="w-full bg-[#b4936c] text-white py-3 px-6 rounded-xl text-base font-medium cursor-pointer transition-all duration-300 ease-in-out shadow-md hover:bg-[#a3825c] hover:translate-y-[-2px] hover:shadow-lg">Découvrir</button>
                </div>
            </div>
        </div>
        <div class="text-center mt-12">
            <button class="bg-[#b4936c] text-white py-4 px-10 rounded-xl text-xl font-semibold cursor-pointer transition-all duration-300 ease-in-out shadow-lg hover:bg-[#a3825c] hover:translate-y-[-3px] hover:shadow-xl">
                <a asp-controller="LivrePage"
                   asp-action="Index"
                   class="text-[#F5F1E8] text-lg font-medium hover:text-white transition-colors duration-200 text-decoration-none">
                    Voir tous les livres
                </a>
            </button>
        </div>
    </section>

    <!-- Section Agenda -->
    <section class="bg-[#b4936c] text-white py-16 mt-16 rounded-3xl shadow-2xl">
        <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-10">
            <h2 class="font-bold text-4xl mb-12 tracking-wide text-center">AGENDA</h2>
            <div class="flex flex-wrap justify-center gap-8 mb-12">
                <!-- Événement 1 -->
                <div class="flex-1 min-w-[300px] max-w-[380px] bg-white rounded-3xl shadow-xl overflow-hidden transition-all duration-300 ease-in-out hover:translate-y-[-8px] hover:shadow-2xl flex flex-col text-gray-900">
                    <div class="w-full aspect-video bg-gray-200 overflow-hidden">
                        <img src="https://www.livreshebdo.fr/sites/default/files/styles/article_principal/public/2022-07/Bob%20lennon.png?itok=6c0srdqx" alt="Image d'une rencontre avec un auteur" class="w-full h-full object-cover transition-transform duration-300 ease-in-out hover:scale-105" />
                    </div>
                    <div class="p-7 flex-grow">
                        <h3 class="text-2xl font-semibold mb-3 leading-snug">Rencontre avec l'auteur Bob Lennon</h3>
                        <p class="text-lg">Discussion et séance de dédicaces avec Bob Lennon, figure emblématique d'internet.</p>
                    </div>
                    <div class="p-7 pt-0">
                        <button class="w-full bg-[#b4936c] text-white py-3 px-6 rounded-xl text-base font-medium cursor-pointer transition-all duration-300 ease-in-out shadow-md hover:bg-[#a3825c] hover:translate-y-[-2px] hover:shadow-lg">Détails</button>
                    </div>
                </div>
                <!-- Événement 2 -->
                <div class="flex-1 min-w-[300px] max-w-[380px] bg-white rounded-3xl shadow-xl overflow-hidden transition-all duration-300 ease-in-out hover:translate-y-[-8px] hover:shadow-2xl flex flex-col text-gray-900">
                    <div class="w-full aspect-video bg-gray-200 overflow-hidden">
                        <img src="https://elsatriolet-varennes.fr/wp-content/uploads/2023/06/sommaire-cine-club-01.jpg" alt="Image d'une projection de ciné-club" class="w-full h-full object-cover transition-transform duration-300 ease-in-out hover:scale-105" />
                    </div>
                    <div class="p-7 flex-grow">
                        <h3 class="text-2xl font-semibold mb-3 leading-snug">Projection Ciné-club : Film Mystère</h3>
                        <p class="text-lg">Venez découvrir un film surprise et en discuter après la séance dans une ambiance conviviale et cinéphile.</p>
                    </div>
                    <div class="p-7 pt-0">
                        <button class="w-full bg-[#b4936c] text-white py-3 px-6 rounded-xl text-base font-medium cursor-pointer transition-all duration-300 ease-in-out shadow-md hover:bg-[#a3825c] hover:translate-y-[-2px] hover:shadow-lg">Réserver</button>
                    </div>
                </div>
                <!-- Événement 3 -->
                <div class="flex-1 min-w-[300px] max-w-[380px] bg-white rounded-3xl shadow-xl overflow-hidden transition-all duration-300 ease-in-out hover:translate-y-[-8px] hover:shadow-2xl flex flex-col text-gray-900">
                    <div class="w-full aspect-video bg-gray-200 overflow-hidden">
                        <img src="https://img.lemde.fr/2021/12/17/0/0/1500/807/960/0/75/0/24d6faf_759027039-7bb2fa7-146690452-capture-d-e-cran-2021-12-17-a-11-12-34.png" class="w-full h-full object-cover transition-transform duration-300 ease-in-out hover:scale-105" />
                    </div>
                    <div class="p-7 flex-grow">
                        <h3 class="text-2xl font-semibold mb-3 leading-snug">Exposition : L'Histoire du Livre</h3>
                        <p class="text-lg">Voyagez à travers les âges et les techniques d'impression, des manuscrits anciens aux livres numériques.</p>
                    </div>
                    <div class="p-7 pt-0">
                        <button class="w-full bg-[#b4936c] text-white py-3 px-6 rounded-xl text-base font-medium cursor-pointer transition-all duration-300 ease-in-out shadow-md hover:bg-[#a3825c] hover:translate-y-[-2px] hover:shadow-lg">Visiter</button>
                    </div>
                </div>
            </div>
            <div class="text-center">
                <button class="bg-white text-[#b4936c] py-4 px-10 rounded-xl text-xl font-semibold cursor-pointer transition-all duration-300 ease-in-out shadow-lg hover:bg-gray-100 hover:translate-y-[-3px] hover:shadow-xl">Voir tous les événements</button>
            </div>
        </div>
    </section>

<style>
    body {
        font-family: 'Inter', sans-serif;
        /* Tailwind's default background-color is usually white, you can override it here if needed */
        /* background-color: #f0f2f5; */
    }
</style>
</main>


@await Html.PartialAsync("_Footer")